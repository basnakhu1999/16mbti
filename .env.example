# Required: RSS source
RSS_URL=https://www.dla.go.th/DlaRssOfficeDoc

# Comma-separated keywords used to match exam/reporting announcements
KEYWORDS=ประกาศรายชื่อสอบ,ประกาศรายชื่อเรียกรายงานตัว,ผลสอบ,รายชื่อผู้มีสิทธิ,ผู้สอบผ่าน,เรียกรายงานตัว,บัญชีผู้สอบแข่งขัน,ขึ้นบัญชี

# Poll interval in seconds (60 = check every minute)
POLL_INTERVAL_SECONDS=60

# true = run loop forever, false = run one round and exit
RUN_FOREVER=true

# State file path to prevent duplicate alerts
STATE_FILE=.dla_rss_state.json

# Telegram (recommended simple setup)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TO=
